---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContentCard from '../components/ContentCard.astro';

const achievements = (await getCollection('achievements', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
);
---

<BaseLayout title="Achievements">
  <section class="space-y-10">
    <PageHeader
      eyebrow="Achievements"
      title="Recognitions and milestones should stay accurate and proportional"
      summary="This page is intended for awards, honors, publications, presentations, and other milestones that support the broader professional profile."
    />

    {achievements.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2">
        {achievements.map((entry) => (
          <ContentCard
            title={entry.data.title}
            summary={entry.data.summary}
            meta={[entry.data.category, entry.data.issuer, entry.data.date].filter(Boolean).join(' · ')}
          />
        ))}
      </div>
    ) : (
      <ContentCard
        title="No achievement entries yet"
        summary="Add entries under src/content/achievements for honors, presentations, publications, or milestones that are ready for public presentation."
      />
    )}
  </section>
</BaseLayout>
