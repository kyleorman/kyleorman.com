---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContentCard from '../components/ContentCard.astro';
import { contactProfiles } from '../data/site';
---

<BaseLayout title="Contact">
  <section class="space-y-10">
    <PageHeader
      eyebrow="Contact"
      title="Keep contact options simple, public-safe, and intentional"
      summary="These public links provide the clearest external references for professional, academic, and technical context without exposing private contact details."
    />

    <div class="grid gap-6 md:grid-cols-2">
      {contactProfiles.map((item) => (
        <ContentCard title={item.label} summary={item.value}>
          <a href={item.href} class="text-sm text-cyan-300 underline transition hover:text-cyan-200" target="_blank" rel="noreferrer">
            Visit link
          </a>
        </ContentCard>
      ))}
    </div>
  </section>
</BaseLayout>
