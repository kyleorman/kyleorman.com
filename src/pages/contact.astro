---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ContentCard from '../components/ContentCard.astro';
import { contactPrompts } from '../data/site';
---

<BaseLayout title="Contact">
  <section class="space-y-10">
    <PageHeader
      eyebrow="Contact"
      title="Keep contact options simple, public-safe, and intentional"
      summary="For the first public version, prioritize a small number of professional contact channels rather than overexposing private information."
    />

    <div class="grid gap-6 md:grid-cols-3">
      {contactPrompts.map((item) => (
        <ContentCard title={item.label} summary={item.value} />
      ))}
    </div>
  </section>
</BaseLayout>
