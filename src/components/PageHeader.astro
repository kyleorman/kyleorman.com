---
interface Props {
  eyebrow?: string;
  title: string;
  summary: string;
}

const { eyebrow, title, summary } = Astro.props;
---

<div class="max-w-3xl space-y-4">
  {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">{eyebrow}</p>}
  <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">{title}</h1>
  <p class="text-lg leading-8 text-slate-300">{summary}</p>
</div>
