---
interface Props {
  title: string;
  summary: string;
  meta?: string;
}

const { title, summary, meta } = Astro.props;
---

<article class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-[0_0_0_1px_rgba(255,255,255,0.02)]">
  <div class="space-y-3">
    {meta && <p class="text-sm font-medium text-cyan-300">{meta}</p>}
    <h2 class="text-xl font-semibold tracking-tight text-white">{title}</h2>
    <p class="leading-7 text-slate-300">{summary}</p>
    <slot />
  </div>
</article>
